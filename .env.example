FLASK_APP=app:create_app
FLASK_DEBUG=1
SECRET_KEY=change-me
DATABASE_URL=sqlite:///instance/timetable.sqlite

# Optional: copy generated timetable history to Supabase PostgREST.
# Set real values in your deployment provider; do not commit production secrets.
SUPABASE_URL=https://your-project.supabase.co
# Vercel/Supabase integrations may provide these NEXT_PUBLIC_* aliases instead.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_KEY=your-publishable-key
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=your-service-or-secret-key
SUPABASE_TIMETABLE_TABLE=timetable_history
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
